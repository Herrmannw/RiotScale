---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const contactEmail = "youngwill9455@gmail.com";
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const formAction = `https://formsubmit.co/${contactEmail}`;
const thankYouUrl = new URL(
  `${baseUrl}thank-you/`,
  Astro.site ?? "https://riotscale.io"
).toString();
const services = [
  "Website Design",
  "SEO",
  "Paid Media",
  "Performance Creative",
  "Growth Planning",
  "Not Sure Yet",
];
---

<BaseLayout
  title="Contact RiotScale | Start a Growth Conversation"
  description="Tell RiotScale what you want to improve online and get next steps for your website, SEO, Google Business Profile, growth planning, or automation needs."
  canonical="/contact/"
>
  <div class="page-shell">
    <Navbar />
    <main>
      <section class="contact-page">
        <div class="contact-inner container">
          <div class="contact-copy">
            <p class="eyebrow">Contact</p>
            <h1>Let's talk about your next growth move.</h1>
            <p>
              Share what you want to improve and we'll help identify a focused
              next step.
            </p>
          </div>

          <form class="contact-form" action={formAction} method="post">
            <input type="text" name="_honey" style="display: none;" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_subject" value="New RiotScale Growth Inquiry" />
            <input type="hidden" name="_next" value={thankYouUrl} />
            <input type="hidden" name="_template" value="table" />

            <div class="form-grid">
              <label>
                <span>Name</span>
                <input type="text" name="name" autocomplete="name" required />
              </label>

              <label>
                <span>Business Name</span>
                <input type="text" name="business_name" autocomplete="organization" />
              </label>

              <label>
                <span>Email</span>
                <input type="email" name="email" autocomplete="email" required />
              </label>

              <label>
                <span>Phone</span>
                <input type="tel" name="phone" autocomplete="tel" />
              </label>

              <label>
                <span>Website URL</span>
                <input type="url" name="website_url" autocomplete="url" />
              </label>

              <label>
                <span>Service Needed</span>
                <select name="service_needed" required>
                  <option value="">Select a service</option>
                  {services.map((service) => <option value={service}>{service}</option>)}
                </select>
              </label>
            </div>

            <label class="form-message">
              <span>Message</span>
              <textarea name="message" rows="6" required></textarea>
            </label>

            <button class="button button-primary" type="submit">Send Message</button>
            <p class="form-note">
              Your details will be sent to the RiotScale team for review.
            </p>
          </form>
        </div>
      </section>
    </main>
    <Footer />
  </div>
</BaseLayout>
