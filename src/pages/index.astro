---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import WhyRiotScale from "../components/WhyRiotScale.astro";
import HomeServices from "../components/HomeServices.astro";
import HomeProcess from "../components/HomeProcess.astro";
import HomeOutcomes from "../components/HomeOutcomes.astro";
import HomeCTA from "../components/HomeCTA.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<BaseLayout
  title="RiotScale | Data-Driven Marketing for Ambitious Brands"
  description="Scale your brand with RiotScale's goal-driven marketing process, actionable plans, and measurable growth strategy for ambitious businesses."
  canonical="/"
>
  <div class="page-shell">
    <Navbar />
    <main>
      <Hero />
      <WhyRiotScale />
      <HomeServices />
      <HomeProcess />
      <HomeOutcomes />
      <HomeCTA />
    </main>
    <Footer />
  </div>
</BaseLayout>
