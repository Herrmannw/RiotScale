---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import blocksImage from "../../assets/ChatGPT Image May 16, 2026, 04_27_05 PM (1).png";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const logos = [
  ["Northline", "Home Services"],
  ["BrightPath", "Learning"],
  ["Summit", "Financial"],
  ["ClearWater", "Plumbing"],
  ["Elevate", "Fitness"],
  ["Pinecrest", "Realty"],
];

const testimonials = [
  ["Michael Thompson", "CEO", "BrightPath Learning", "The team at RiotScale is responsive, strategic, and truly invested in our success. Our pipeline has never been stronger."],
  ["Rachel Adams", "Marketing Director", "Elevate Fitness", "Their paid media strategy and conversion optimization increased our ROAS by 176% in just 90 days."],
  ["David Chen", "Founder", "Summit Financial", "RiotScale brings clarity, creativity, and measurable outcomes to every campaign. They're a true growth partner."],
  ["Lauren Patel", "Head of Marketing", "Pinecrest Realty", "From SEO to paid search, everything they touch moves the needle. We've seen a 3X increase in organic traffic."],
  ["James Walker", "Operations Manager", "ClearWater Plumbing", "Professional, transparent, and results-driven. RiotScale helped us scale efficiently without wasting budget."],
  ["Emily Rodriguez", "Growth Marketing Manager", "Northline Home Services", "Our cost per lead dropped 42% while lead quality improved dramatically. We couldn't be happier."],
];

const stats = [
  ["218%", "Average Increase in Qualified Leads"],
  ["42%", "Average Reduction in Cost Per Acquisition"],
  ["76%", "Average Increase in Conversion Rate"],
  ["95%", "Client Retention Rate"],
];

const reasons = [
  ["Results-Driven Strategy", "We focus on what moves the needle and delivers measurable growth."],
  ["Transparent & Collaborative", "Clear communication, full visibility, and true partnership."],
  ["Deep Expertise", "A senior team with cross-channel expertise and industry knowledge."],
  ["Continuous Optimization", "We test, learn, and optimize to compound results over time."],
];
---

<BaseLayout
  title="Client Testimonials | RiotScale"
  description="See how ambitious businesses describe working with RiotScale to improve lead generation, conversion rates, organic traffic, and measurable marketing results."
  canonical="/testimonials/"
>
  <div class="page-shell">
    <Navbar />
    <main>
      <section class="testimonials-hero">
        <div class="testimonials-hero-inner container">
          <div class="testimonials-copy">
            <h1>What our clients say.</h1>
            <p>
              Trusted by ambitious businesses to drive real growth through
              data-driven marketing, creative strategy, and measurable results.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href={`${baseUrl}contact/`}>Let's Talk</a>
              <a class="text-link" href={`${baseUrl}contact/`}>
                Start a Conversation
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h13"></path>
                  <path d="m13 6 6 6-6 6"></path>
                </svg>
              </a>
            </div>
          </div>

          <article class="featured-testimonial">
            <div class="featured-quote">
              <span aria-hidden="true">“</span>
              <p>
                RiotScale completely transformed our lead generation. We saw a
                218% increase in qualified leads and a 42% reduction in customer
                acquisition cost in just 6 months.
              </p>
              <div class="client-row">
                <span class="client-avatar">JM</span>
                <div>
                  <h2>Jessica Morgan</h2>
                  <p>VP of Marketing<br />Northline Home Services</p>
                </div>
              </div>
            </div>
            <div class="client-photo" aria-hidden="true">
              <span>RIOTSCALE</span>
              <i></i>
              <i></i>
              <i></i>
              <i></i>
              <i></i>
            </div>
          </article>
        </div>
      </section>

      <section class="trusted-panel container">
        <p class="eyebrow">Trusted By Growing Businesses</p>
        <div class="logo-row">
          {
            logos.map(([name, industry]) => (
              <div class="client-logo">
                <span>{name}</span>
                <small>{industry}</small>
              </div>
            ))
          }
        </div>
      </section>

      <section class="testimonial-section container">
        <h2>More from our clients</h2>
        <div class="testimonial-grid">
          {
            testimonials.map(([name, role, company, quote]) => (
              <article class="testimonial-card">
                <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
                <p>“{quote}”</p>
                <div class="client-row">
                  <span class="client-avatar">{name.split(" ").map((part) => part[0]).join("")}</span>
                  <div>
                    <h3>{name}</h3>
                    <p>{role}<br />{company}</p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="stats-panel container">
        {
          stats.map(([number, label]) => (
            <article class="stat-item">
              <span></span>
              <div>
                <h2>{number}</h2>
                <p>{label}</p>
              </div>
            </article>
          ))
        }
      </section>

      <section class="client-reasons container">
        <h2>Why clients stay with RiotScale</h2>
        <div class="reason-strip">
          {
            reasons.map(([title, body]) => (
              <article>
                <span></span>
                <div>
                  <h3>{title}</h3>
                  <p>{body}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="services-cta container">
        <div>
          <p class="eyebrow">/ Ready To Grow?</p>
          <h2>Let's Build What's Next.</h2>
          <p>
            Tell us about your goals and we'll show you how RiotScale can help
            you achieve them.
          </p>
        </div>
        <div class="hero-actions">
          <a class="button button-secondary" href={`${baseUrl}contact/`}>Let's Talk</a>
          <a class="text-link" href={`${baseUrl}contact/`}>
            Start a Conversation
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h13"></path>
              <path d="m13 6 6 6-6 6"></path>
            </svg>
          </a>
        </div>
        <img src={blocksImage.src} alt="" loading="lazy" decoding="async" />
      </section>
    </main>
  </div>
</BaseLayout>
