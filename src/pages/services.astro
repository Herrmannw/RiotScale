---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import blocksImage from "../../assets/ChatGPT Image May 16, 2026, 04_27_05 PM (1).png";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const services = [
  ["Website Design", "Clarify the customer journey, define conversion goals, and shape a site experience around the actions that matter.", "monitor"],
  ["Public Relations", "Set credibility goals, identify the right stories, and build a repeatable process for trust and visibility.", "megaphone"],
  ["Website Development", "Turn the strategy into a fast, secure site with a clear build process and quality benchmarks.", "code"],
  ["SEO", "Map search opportunities to business goals, then prioritize technical, content, and authority-building work.", "search"],
  ["Paid Media", "Build campaigns around acquisition goals, test creative intentionally, and scale what the data supports.", "bars"],
  ["Analytics & CRO", "Create measurement habits that show what is working and where the process should improve.", "chart"],
];

const process = [
  ["Discover", "We clarify your business goals, audience, and current growth process."],
  ["Strategize", "We translate those goals into priorities, milestones, and success metrics."],
  ["Execute", "We move through the plan in focused cycles with clear ownership and timing."],
  ["Analyze", "We review progress against the goal, then identify what needs to change."],
  ["Optimize", "We refine the process, scale what works, and keep the next goal visible."],
];

const goals = [
  ["Clear Goals", "Define what growth should mean before choosing channels or tactics."],
  ["Focused Plan", "Prioritize the moves most likely to create measurable momentum."],
  ["Steady Rhythm", "Use a practical working cadence that keeps strategy moving."],
  ["Sharper Scale", "Review, learn, and improve the process as the goals evolve."],
];
---

<BaseLayout
  title="Goal-Driven Marketing Process | RiotScale"
  description="Explore how RiotScale clarifies growth goals, builds a focused marketing process, and improves the systems that help ambitious brands scale."
  canonical="/services/"
>
  <div class="page-shell">
    <Navbar />
    <main>
      <section class="services-hero">
        <div class="services-hero-inner container">
          <div class="services-copy">
            <p class="eyebrow">/ Services</p>
            <h1>Marketing Built Around Goals And Process.</h1>
            <p>
              We partner with ambitious brands to clarify what growth should
              look like, build the process to pursue it, and improve the systems
              that make progress measurable.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href={`${baseUrl}contact/`}>Let's Talk About Your Growth</a>
              <a class="text-link" href={`${baseUrl}testimonials/`}>
                View Testimonials
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h13"></path>
                  <path d="m13 6 6 6-6 6"></path>
                </svg>
              </a>
            </div>
          </div>

          <div class="device-showcase" aria-label="Website and mobile preview placeholder">
            <div class="laptop-frame">
              <div class="mock-nav">
                <span>RIOTSCALE</span>
                <small>Work</small>
                <small>Services</small>
                <small>About</small>
              </div>
              <h2>Clear Goals. Steady Growth.</h2>
              <p>A focused process for brands ready to scale with intention.</p>
              <div class="mock-blocks">
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>
            <div class="phone-frame">
              <p>Goals.<br />Process.<br />Progress.</p>
              <span></span>
            </div>
            <aside class="media-card media-card-top">
              <small>Process Focus</small>
              <strong>Goals</strong>
              <strong>Clarity</strong>
            </aside>
            <aside class="media-card media-card-bottom">
              <small>Planning Rhythm</small>
              <strong>Weekly</strong>
              <span>Review Cycle</span>
            </aside>
          </div>
        </div>
      </section>

      <section class="services-section">
        <div class="services-intro container">
          <div>
            <p class="eyebrow">/ What We Do</p>
            <h2>Growth Goals With A Clear Process</h2>
          </div>
          <p>
            Every engagement starts with the goal you want, then becomes a
            practical operating plan across strategy, creative, media, and
            measurement.
          </p>
        </div>

        <div class="service-card-grid container">
          {
            services.map(([title, body, icon]) => (
              <article class="service-card">
                <span class="service-icon">
                  {icon === "monitor" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <rect x="5" y="7" width="22" height="16" rx="2"></rect>
                      <path d="M12 27h8"></path>
                      <path d="M16 23v4"></path>
                    </svg>
                  )}
                  {icon === "megaphone" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M7 18h5l11 5V9L12 14H7v4Z"></path>
                      <path d="M12 18v7"></path>
                    </svg>
                  )}
                  {icon === "code" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="m12 10-6 6 6 6"></path>
                      <path d="m20 10 6 6-6 6"></path>
                      <path d="m18 7-4 18"></path>
                    </svg>
                  )}
                  {icon === "search" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <circle cx="14" cy="14" r="8"></circle>
                      <path d="m20 20 6 6"></path>
                    </svg>
                  )}
                  {icon === "bars" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M7 25V14"></path>
                      <path d="M16 25V8"></path>
                      <path d="M25 25V18"></path>
                    </svg>
                  )}
                  {icon === "chart" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M16 5v11h11"></path>
                      <path d="M25 20a10 10 0 1 1-9-15"></path>
                    </svg>
                  )}
                </span>
                <div>
                  <h3>{title}</h3>
                  <p>{body}</p>
                  <a class="mini-link" href={`${baseUrl}contact/`}>Learn More <span aria-hidden="true">-></span></a>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="services-process container">
        <div class="process-header">
          <div>
            <p class="eyebrow">/ How We Work</p>
            <h2>A Clear Process. Visible Progress.</h2>
          </div>
          <p>
            Our methodology keeps the goal in view while strategy, creative,
            data, and continuous optimization move together.
          </p>
        </div>
        <div class="service-process-steps">
          {
            process.map(([title, body], index) => (
              <article>
                <span>{index + 1}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="service-outcomes container">
        <div>
          <p class="eyebrow">/ Goals & Process</p>
          <h2>Built Around Where You Want To Go</h2>
        </div>
        {
          goals.map(([goal, label]) => (
            <article>
              <span></span>
              <h3>{goal}</h3>
              <p>{label}</p>
            </article>
          ))
        }
      </section>

      <section class="services-cta container">
        <div>
          <p class="eyebrow">/ Ready To Grow?</p>
          <h2>Let's Build What's Next.</h2>
          <p>
            Tell us about your goals and we'll show you how RiotScale can help
            you achieve them.
          </p>
        </div>
        <div class="hero-actions">
          <a class="button button-secondary" href={`${baseUrl}contact/`}>Let's Talk</a>
          <a class="text-link" href={`${baseUrl}testimonials/`}>
            See Testimonials
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h13"></path>
              <path d="m13 6 6 6-6 6"></path>
            </svg>
          </a>
        </div>
        <img src={blocksImage.src} alt="" loading="lazy" decoding="async" />
      </section>
    </main>
  </div>
</BaseLayout>
