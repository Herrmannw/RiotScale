---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import blocksImage from "../../assets/ChatGPT Image May 16, 2026, 04_27_05 PM (1).png";
import servicesHeroImage from "../../assets/why-planning-board.png";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const services = [
  ["Website Strategy", "Clarify the customer journey and conversion goals before design begins.", "monitor"],
  ["Website Design", "Create a polished site experience built for trust and action.", "code"],
  ["SEO", "Prioritize search opportunities that support real business goals.", "search"],
  ["Paid Media", "Test campaigns intentionally and scale what the data supports.", "bars"],
  ["Performance Creative", "Shape messages and assets around attention, clarity, and action.", "megaphone"],
  ["Analytics & CRO", "Measure what matters and improve the path to conversion.", "chart"],
];

const process = [
  ["Discover", "Clarify goals, audience, and current gaps."],
  ["Strategize", "Turn the signal into priorities and success metrics."],
  ["Execute", "Move through the plan in focused cycles."],
  ["Optimize", "Review, learn, and improve the system."],
];

const goals = [
  ["Clarity", "Know what matters first."],
  ["Focus", "Spend effort where it can move the needle."],
  ["Rhythm", "Keep decisions and execution moving."],
  ["Scale", "Improve the system as momentum builds."],
];
---

<BaseLayout
  title="Goal-Driven Marketing Process | RiotScale"
  description="Explore how RiotScale clarifies growth goals, builds a focused marketing process, and improves the systems that help ambitious brands scale."
  canonical="/services/"
>
  <div class="page-shell">
    <Navbar />
    <main>
      <section class="services-hero">
        <div class="services-hero-inner container">
          <div class="services-copy">
            <p class="eyebrow">/ Services</p>
            <h1>Marketing Built Around Goals And Process.</h1>
            <p>
              Strategy, creative, web, search, and measurement arranged around
              the outcomes your business needs most.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href={`${baseUrl}contact/`}>Let's Talk</a>
              <a class="text-link" href={`${baseUrl}about-us/`}>
                About RiotScale
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h13"></path>
                  <path d="m13 6 6 6-6 6"></path>
                </svg>
              </a>
            </div>
          </div>

          <div class="services-visual generated-image-frame">
            <img
              src={servicesHeroImage.src}
              alt="Planning board with wireframes, campaign notes, and burgundy strategy marks."
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </section>

      <section class="services-section">
        <div class="services-intro container">
          <div>
            <p class="eyebrow">/ What We Do</p>
            <h2>Growth Goals With A Clear Process</h2>
          </div>
          <p>
            Every engagement starts with the result you want, then becomes a
            focused operating plan.
          </p>
        </div>

        <div class="service-card-grid container">
          {
            services.map(([title, body, icon]) => (
              <article class="service-card">
                <span class="service-icon">
                  {icon === "monitor" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <rect x="5" y="7" width="22" height="16" rx="2"></rect>
                      <path d="M12 27h8"></path>
                      <path d="M16 23v4"></path>
                    </svg>
                  )}
                  {icon === "megaphone" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M7 18h5l11 5V9L12 14H7v4Z"></path>
                      <path d="M12 18v7"></path>
                    </svg>
                  )}
                  {icon === "code" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="m12 10-6 6 6 6"></path>
                      <path d="m20 10 6 6-6 6"></path>
                      <path d="m18 7-4 18"></path>
                    </svg>
                  )}
                  {icon === "search" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <circle cx="14" cy="14" r="8"></circle>
                      <path d="m20 20 6 6"></path>
                    </svg>
                  )}
                  {icon === "bars" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M7 25V14"></path>
                      <path d="M16 25V8"></path>
                      <path d="M25 25V18"></path>
                    </svg>
                  )}
                  {icon === "chart" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M16 5v11h11"></path>
                      <path d="M25 20a10 10 0 1 1-9-15"></path>
                    </svg>
                  )}
                </span>
                <div>
                  <h3>{title}</h3>
                  <p>{body}</p>
                  <a class="mini-link" href={`${baseUrl}contact/`}>Start Here <span aria-hidden="true">-></span></a>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="services-process container">
        <div class="process-header">
          <div>
            <p class="eyebrow">/ How We Work</p>
            <h2>A Clear Process. Visible Progress.</h2>
          </div>
          <p>
            A simple rhythm keeps strategy, creative, and measurement moving
            together.
          </p>
        </div>
        <div class="service-process-steps">
          {
            process.map(([title, body], index) => (
              <article>
                <span>{index + 1}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="service-outcomes container">
        <div>
          <p class="eyebrow">/ Goals & Process</p>
          <h2>Built Around Where You Want To Go</h2>
        </div>
        {
          goals.map(([goal, label]) => (
            <article>
              <span></span>
              <h3>{goal}</h3>
              <p>{label}</p>
            </article>
          ))
        }
      </section>

      <section class="services-cta container">
        <div>
          <p class="eyebrow">/ Ready To Grow?</p>
          <h2>Let's Build What's Next.</h2>
          <p>
            Tell us what you want to improve. We'll help map the next move.
          </p>
        </div>
        <div class="hero-actions">
          <a class="button button-secondary" href={`${baseUrl}contact/`}>Let's Talk</a>
          <a class="text-link" href={`${baseUrl}about-us/`}>
            About RiotScale
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h13"></path>
              <path d="m13 6 6 6-6 6"></path>
            </svg>
          </a>
        </div>
        <img src={blocksImage.src} alt="" loading="lazy" decoding="async" />
      </section>
    </main>
    <Footer />
  </div>
</BaseLayout>
