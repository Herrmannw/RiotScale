---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import blocksImage from "../../assets/ChatGPT Image May 16, 2026, 04_27_05 PM (1).png";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const values = [
  {
    title: "Strategic",
    body: "Every decision starts with the business goal.",
    icon: "target",
  },
  {
    title: "Transparent",
    body: "Clear priorities, direct communication, no mystery work.",
    icon: "eye",
  },
  {
    title: "Creative",
    body: "Messaging shaped for attention, trust, and action.",
    icon: "spark",
  },
  {
    title: "Performance",
    body: "Measurement habits that keep the work improving.",
    icon: "growth",
  },
];

const process = [
  ["Discover", "Clarify goals, audience, offers, and current gaps."],
  ["Plan", "Set priorities across message, channel, and measurement."],
  ["Execute", "Move in focused cycles with visible next steps."],
  ["Improve", "Measure what matters and keep refining the system."],
];
---

<BaseLayout
  title="About RiotScale | Strategic Marketing Partner"
  description="Learn how RiotScale builds goal-driven marketing systems that help ambitious brands grow with clarity, creative strategy, and practical process."
  canonical="/about-us/"
>
  <div class="page-shell">
    <Navbar />
    <main>
      <section class="about-hero">
        <div class="about-hero-inner container">
          <div class="about-hero-copy">
            <p class="eyebrow">About RiotScale</p>
            <h1>We build marketing systems that help ambitious brands grow.</h1>
            <p>
              RiotScale blends strategy, creative, and measurement into clear
              growth plans for businesses ready to move with more focus.
            </p>
          </div>

          <div class="about-blocks-card" aria-hidden="true">
            <img src={blocksImage.src} alt="" loading="eager" decoding="async" />
          </div>
        </div>
      </section>

      <section class="about-band">
        <div class="story-grid container">
          <div>
            <p class="eyebrow">Our Story</p>
            <h2>Clear thinking before noisy tactics.</h2>
          </div>
          <div class="story-copy">
            <p>
              Marketing gets expensive when teams chase every channel at once.
              We help narrow the field, sharpen the message, and focus the work
              around measurable progress.
            </p>
          </div>
          <div class="story-copy">
            <p>
              The result is a practical system: better priorities, cleaner
              creative direction, and a rhythm for learning what actually moves
              the business forward.
            </p>
          </div>
        </div>
      </section>

      <section class="about-band values-band">
        <div class="values-grid container">
          <p class="eyebrow">Our Values</p>
          {
            values.map((value) => (
              <article class="value-card">
                <span class="value-icon">
                  {value.icon === "target" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <circle cx="16" cy="16" r="10"></circle>
                      <circle cx="16" cy="16" r="4"></circle>
                      <path d="m18.8 13.2 5.7-5.7"></path>
                      <path d="M23 4h5v5"></path>
                    </svg>
                  )}
                  {value.icon === "eye" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M3.5 16s4.5-8 12.5-8 12.5 8 12.5 8-4.5 8-12.5 8S3.5 16 3.5 16Z"></path>
                      <circle cx="16" cy="16" r="3.5"></circle>
                    </svg>
                  )}
                  {value.icon === "spark" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M16 3v5"></path>
                      <path d="M16 24v5"></path>
                      <path d="M5 16h5"></path>
                      <path d="M22 16h5"></path>
                      <path d="m8 8 3.5 3.5"></path>
                      <path d="m20.5 20.5 3.5 3.5"></path>
                      <circle cx="16" cy="16" r="4.5"></circle>
                    </svg>
                  )}
                  {value.icon === "growth" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M5 25h22"></path>
                      <path d="M8 22v-5"></path>
                      <path d="M15 22v-9"></path>
                      <path d="M22 22V8"></path>
                      <path d="m19 8 3-3 3 3"></path>
                    </svg>
                  )}
                </span>
                <h3>{value.title}</h3>
                <p>{value.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="about-band">
        <div class="process-grid container">
          <div class="process-intro">
            <p class="eyebrow">How We Work</p>
            <h2>A lean process built around your goals.</h2>
          </div>
          {
            process.map(([title, body], index) => (
              <article class="process-step">
                <span>{index + 1}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="services-cta container">
        <div>
          <p class="eyebrow">/ Ready To Grow?</p>
          <h2>Let's Build What's Next.</h2>
          <p>
            Tell us what you want to improve. We'll help map the next move.
          </p>
        </div>
        <div class="hero-actions">
          <a class="button button-secondary" href={`${baseUrl}contact/`}>Let's Talk</a>
          <a class="text-link" href={`${baseUrl}services/`}>
            Explore Services
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h13"></path>
              <path d="m13 6 6 6-6 6"></path>
            </svg>
          </a>
        </div>
        <img src={blocksImage.src} alt="" loading="lazy" decoding="async" />
      </section>
    </main>
    <Footer />
  </div>
</BaseLayout>
