---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import FounderPortrait from "../components/FounderPortrait.jsx";
import blocksImage from "../../assets/ChatGPT Image May 16, 2026, 04_27_05 PM (1).png";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const values = [
  {
    title: "Strategic",
    body: "Every decision starts with the business goal, then moves into channel, creative, and measurement.",
    icon: "target",
  },
  {
    title: "Transparent",
    body: "Clear priorities, direct communication, and no mystery work hiding behind polished dashboards.",
    icon: "eye",
  },
  {
    title: "Creative",
    body: "Creative is shaped around what people need to notice, remember, and trust enough to act on.",
    icon: "spark",
  },
  {
    title: "Process",
    body: "We focus on goals, actionable plans, and systems that improve every cycle.",
    icon: "growth",
  },
];

const process = [
  ["Discover", "We study your market, audience, goals, and current growth process."],
  ["Strategize", "We turn the signal into focused priorities across messaging, media, and measurement."],
  ["Execute", "We move through the plan in clear cycles with tight feedback loops."],
  ["Optimize", "We measure what matters, learn quickly, and improve the system."],
];

const milestones = [
  ["2018", "The Beginning"],
  ["2019", "First Partnerships"],
  ["2020", "Scaling Impact"],
  ["2022", "Global Reach"],
  ["2024+", "The Next Chapter"],
];
---

<BaseLayout
  title="About RiotScale | Strategic Marketing Partner"
  description="Learn how RiotScale builds goal-driven marketing systems that help ambitious brands grow with clarity, creative strategy, and practical process."
  canonical="/about-us/"
>
  <div class="page-shell">
    <Navbar />
    <main>
      <section class="about-hero">
        <div class="about-hero-inner container">
          <div class="about-hero-copy">
            <p class="eyebrow">About RiotScale</p>
            <h1>We build marketing systems that help ambitious brands grow.</h1>
            <p>
              RiotScale is a data-driven marketing partner for companies that are
              ready to scale. We blend strategy, creative, and process into
              repeatable systems that clarify the right audience, define the next
              steps, and support measurable growth.
            </p>
          </div>

          <div class="about-studio" aria-label="RiotScale strategy session">
            <div class="studio-wall">RIOTSCALE</div>
            <div class="studio-table"></div>
            <span class="studio-person person-one"></span>
            <span class="studio-person person-two"></span>
            <span class="studio-person person-three"></span>
            <span class="studio-person person-four"></span>
          </div>
        </div>
      </section>

      <section class="about-band">
        <div class="story-grid container">
          <div>
            <p class="eyebrow">Our Story</p>
            <h2>Founded on curiosity. Guided by goals. Built for long-term impact.</h2>
          </div>
          <div class="story-copy">
            <p>
              RiotScale began with a simple belief: marketing should do more than
              look good. It should move the needle. After years inside agencies and
              in-house teams, we saw the same problems repeat: fragmented strategy,
              unclear priorities, and a lack of true partnership.
            </p>
            <p>
              We started RiotScale to do things differently. To build a team that
              cares about the business goals behind every campaign, and to create
              systems that support consistent, compounding growth.
            </p>
          </div>
          <div class="story-copy">
            <p>
              Today, we partner with ambitious brands across industries, from B2B
              SaaS to commerce and professional services, helping them scale with
              clarity, speed, and confidence.
            </p>
            <p>We're not here for quick wins. We're here to build what lasts.</p>
          </div>
        </div>
      </section>

      <section class="about-band values-band">
        <div class="values-grid container">
          <p class="eyebrow">Our Values</p>
          {
            values.map((value) => (
              <article class="value-card">
                <span class="value-icon">
                  {value.icon === "target" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <circle cx="16" cy="16" r="10"></circle>
                      <circle cx="16" cy="16" r="4"></circle>
                      <path d="m18.8 13.2 5.7-5.7"></path>
                      <path d="M23 4h5v5"></path>
                    </svg>
                  )}
                  {value.icon === "eye" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M3.5 16s4.5-8 12.5-8 12.5 8 12.5 8-4.5 8-12.5 8S3.5 16 3.5 16Z"></path>
                      <circle cx="16" cy="16" r="3.5"></circle>
                    </svg>
                  )}
                  {value.icon === "spark" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M16 3v5"></path>
                      <path d="M16 24v5"></path>
                      <path d="M5 16h5"></path>
                      <path d="M22 16h5"></path>
                      <path d="m8 8 3.5 3.5"></path>
                      <path d="m20.5 20.5 3.5 3.5"></path>
                      <circle cx="16" cy="16" r="4.5"></circle>
                    </svg>
                  )}
                  {value.icon === "growth" && (
                    <svg viewBox="0 0 32 32" aria-hidden="true">
                      <path d="M5 25h22"></path>
                      <path d="M8 22v-5"></path>
                      <path d="M15 22v-9"></path>
                      <path d="M22 22V8"></path>
                      <path d="m19 8 3-3 3 3"></path>
                    </svg>
                  )}
                </span>
                <h3>{value.title}</h3>
                <p>{value.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="about-band" id="founder">
        <div class="team-section container">
          <p class="eyebrow">Meet The Founder</p>
          <FounderPortrait client:load />
        </div>
      </section>

      <section class="about-band">
        <div class="process-grid container">
          <div class="process-intro">
            <p class="eyebrow">How We Work</p>
            <h2>A clear process, built around your goals.</h2>
          </div>
          {
            process.map(([title, body], index) => (
              <article class="process-step">
                <span>{index + 1}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="about-band">
        <div class="journey container">
          <p class="eyebrow">Our Journey</p>
          <div class="journey-line">
            {
              milestones.map(([year, label]) => (
                <article class="milestone">
                  <span></span>
                  <h3>{year}</h3>
                  <p>{label}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="services-cta container">
        <div>
          <p class="eyebrow">/ Ready To Grow?</p>
          <h2>Let's Build What's Next.</h2>
          <p>
            Tell us about your goals and we'll show you how RiotScale can help
            you achieve them.
          </p>
        </div>
        <div class="hero-actions">
          <a class="button button-secondary" href={`${baseUrl}contact/`}>Let's Talk</a>
          <a class="text-link" href={`${baseUrl}testimonials/`}>
            See Testimonials
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h13"></path>
              <path d="m13 6 6 6-6 6"></path>
            </svg>
          </a>
        </div>
        <img src={blocksImage.src} alt="" loading="lazy" decoding="async" />
      </section>
    </main>
  </div>
</BaseLayout>
