---
import whyImage from "../../assets/why-strategy-map.png";

const reasons = [
  {
    title: "Performance Focused",
    body: "Work is tied to outcomes your team can measure.",
  },
  {
    title: "Data-Informed Strategy",
    body: "Signals guide priorities, budgets, and next moves.",
  },
  {
    title: "Creative That Converts",
    body: "Messaging and visuals are built to move people.",
  },
  {
    title: "Scalable Growth",
    body: "Plans are structured to improve as momentum builds.",
  },
];

---

<section class="why" aria-labelledby="why-title">
  <div class="why-inner container">
    <div class="why-layout">
      <div class="section-intro">
        <p class="eyebrow">/ Why RiotScale</p>
        <h2 id="why-title">Strategic. Data-Driven. Built to Perform.</h2>
        <p>
          A lean marketing partner for brands that want clear priorities,
          stronger creative, and measurable movement.
        </p>
      </div>

      <figure class="why-visual">
        <img
          src={whyImage.src}
          alt="Abstract burgundy strategy map showing connected signals, planning nodes, and upward growth paths."
          loading="lazy"
          decoding="async"
        />
      </figure>

      <div class="reason-grid">
        {
          reasons.map((reason, index) => (
            <article class="reason-card">
              <span class="reason-icon">{index + 1}</span>
              <div>
                <h3>{reason.title}</h3>
                <p>{reason.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
