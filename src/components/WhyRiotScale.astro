---
const reasons = [
  {
    title: "Clarify The Goal",
    body: "We define what growth should look like before recommending channels.",
  },
  {
    title: "Build The Process",
    body: "We turn strategy into focused priorities, timelines, and measurement habits.",
  },
  {
    title: "Improve The System",
    body: "We review progress, refine the plan, and keep improving what works.",
  },
];

---

<section class="why" aria-labelledby="why-title">
  <div class="why-inner container">
    <div class="why-layout">
      <div class="section-intro">
        <p class="eyebrow">/ Why RiotScale</p>
        <h2 id="why-title">Clear goals. Strong process. Measurable growth.</h2>
        <p>
          Our work starts with what the business needs, then turns that goal into
          a practical process your team can understand and improve.
        </p>
      </div>

      <div class="reason-grid">
        {
          reasons.map((reason, index) => (
            <article class="reason-card">
              <span class="reason-icon">{index + 1}</span>
              <div>
                <h3>{reason.title}</h3>
                <p>{reason.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
