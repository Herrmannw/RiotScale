---
const reasons = [
  {
    title: "Discover & Strategize",
    body: "We analyze your business, your market, and your goals.",
  },
  {
    title: "Build & Execute",
    body: "We build high-performance systems that drive consistent results.",
  },
  {
    title: "Optimize & Scale",
    body: "We continuously optimize to increase results over time.",
  },
];

const logos = ["Southside Auto", "Elevate Dental", "Redwood Roofing", "Peak Fitness"];
---

<section class="why" aria-labelledby="why-title">
  <div class="why-inner container">
    <div class="why-layout">
      <div class="section-intro">
        <p class="eyebrow">/ Why RiotScale</p>
        <h2 id="why-title">We turn marketing into measurable business growth.</h2>
        <p>
          Our strategies are built on a foundation of creativity, real data and
          results that matter.
        </p>
        <a class="text-link" href="#approach">
          Learn Our Approach
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h13"></path>
            <path d="m13 6 6 6-6 6"></path>
          </svg>
        </a>
      </div>

      <div class="reason-grid" id="approach">
        {
          reasons.map((reason, index) => (
            <article class="reason-card">
              <span class="reason-icon">{index + 1}</span>
              <div>
                <h3>{reason.title}</h3>
                <p>{reason.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="trusted-row">
      <p>Trusted by local businesses that are growing fast.</p>
      {logos.map((logo) => <span>{logo}</span>)}
    </div>
  </div>
</section>
