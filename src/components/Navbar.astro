---
const baseUrl = import.meta.env.BASE_URL;
const pageHref = (path = "") => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  return `${base}${path}`;
};

const navItems = [
  { label: "About Us", href: pageHref("about-us/") },
  { label: "Services", href: pageHref("services/") },
  { label: "Our Approach", href: "#" },
  { label: "Testimonials", href: pageHref("testimonials/") },
  { label: "Insights", href: "#" },
  { label: "Contact", href: pageHref("contact/") },
];
---

<header class="navbar" aria-label="Primary navigation">
  <div class="navbar-inner container">
    <a class="brand" href={pageHref()} aria-label="RiotScale home">RIOTSCALE</a>

    <nav class="nav-links" aria-label="Main menu">
      {
        navItems.map((item) => (
          <a href={item.href} aria-label={`${item.label} section`}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions">
      <a class="button button-primary" href={pageHref("contact/")}>Let's Talk</a>
      <a class="button button-secondary" href="#">Client Login</a>
    </div>
  </div>
</header>
