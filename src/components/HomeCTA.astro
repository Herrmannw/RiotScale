---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const focusAreas = ["Strategy", "Creative", "Web", "Search", "Media", "Measurement"];
---

<section class="home-cta" aria-labelledby="home-cta-title">
  <div class="home-cta-inner container">
    <div>
      <p class="eyebrow">/ Ready To Grow?</p>
      <h2 id="home-cta-title">Let's Build What's Next.</h2>
      <p>
        Tell us what needs to improve. We'll help turn the moving pieces into a
        focused next step.
      </p>
    </div>

    <div class="home-cta-panel">
      <div class="home-chip-row" aria-label="RiotScale focus areas">
        {focusAreas.map((area) => <span>{area}</span>)}
      </div>
      <div class="hero-actions">
        <a class="button button-secondary" href={`${baseUrl}contact/`}>Let's Talk</a>
        <a class="text-link" href={`${baseUrl}services/`}>
          Explore Services
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h13"></path>
            <path d="m13 6 6 6-6 6"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
