---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const services = [
  {
    icon: "website",
    title: "Website Design",
    body: "Conversion-focused websites that build trust and drive action.",
  },
  {
    icon: "local",
    title: "Local SEO",
    body: "Get found by local searchers and turn them into customers.",
  },
  {
    icon: "reputation",
    title: "Reputation Growth",
    body: "Turn reviews into trust, credibility, and five-star competitors.",
  },
  {
    icon: "leads",
    title: "Lead Capture Systems",
    body: "Smart lead forms, automations, and CRM that convert more.",
  },
];

const stats = [
  { value: "100+", label: "Businesses Scaled" },
  { value: "2.4X", label: "Average ROI Increase" },
  { value: "$50M+", label: "Revenue Generated" },
  { value: "4.9", label: "Average Client Rating" },
];
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-inner container">
    <div class="hero-content">
      <h1 id="hero-title">
        <span>Scale Your Brand.</span>
        <span>Maximize Impact.</span>
      </h1>
      <p>
        We help ambitious businesses unlock growth through data-driven marketing,
        performance creative, and measurable strategy.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={`${baseUrl}services/`}>Explore Our Services</a>
        <a class="text-link" href={`${baseUrl}testimonials/`}>
          View Testimonials
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h13"></path>
            <path d="m13 6 6 6-6 6"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="visual-orbit"></div>
      <div class="browser-card">
        <div class="browser-top"><span></span><span></span><span></span></div>
        <div class="business-row"><strong>R</strong><span>Your Business</span></div>
        <div class="image-placeholder"></div>
        <div class="content-lines"><span></span><span></span><span></span></div>
        <div class="thumb-row"><i></i><i></i><i></i></div>
      </div>
      <div class="quote-card">
        <strong>Get a Free Quote</strong>
        <span></span><span></span><span></span><span></span>
        <b>Send Request</b>
      </div>
      <div class="review-card">
        <strong>G</strong>
        <span>4.9 ★★★★★</span>
        <small>Based on 120+ reviews</small>
      </div>
      <div class="leads-card">
        <span>New Leads</span>
        <strong>+132</strong>
        <small>↑ 23% from last month</small>
      </div>
    </div>
  </div>

  <div class="service-strip container" aria-label="Core services">
    {
      services.map((service) => (
        <article class="service-tile">
          <span class="service-symbol" aria-hidden="true">
            {service.icon === "website" && (
              <svg viewBox="0 0 32 32">
                <rect x="5" y="7" width="22" height="16" rx="1.8"></rect>
                <path d="M12 27h8"></path>
                <path d="M16 23v4"></path>
                <path d="M9 12h5"></path>
                <path d="M9 16h10"></path>
                <path d="M22 12h1"></path>
              </svg>
            )}
            {service.icon === "local" && (
              <svg viewBox="0 0 32 32">
                <path d="M16 28s8-7.6 8-15a8 8 0 0 0-16 0c0 7.4 8 15 8 15Z"></path>
                <circle cx="16" cy="13" r="3"></circle>
              </svg>
            )}
            {service.icon === "reputation" && (
              <svg viewBox="0 0 32 32">
                <path d="M6 14h7l9-5v14l-9-5H6v-4Z"></path>
                <path d="M13 18v6"></path>
                <path d="M25 13c1.2 1.8 1.2 4.2 0 6"></path>
              </svg>
            )}
            {service.icon === "leads" && (
              <svg viewBox="0 0 32 32">
                <path d="M9 6v10a7 7 0 0 0 14 0V6"></path>
                <path d="M9 6h5"></path>
                <path d="M18 6h5"></path>
                <path d="M9 11h5"></path>
                <path d="M18 11h5"></path>
              </svg>
            )}
          </span>
          <h2>{service.title}</h2>
          <p>{service.body}</p>
        </article>
      ))
    }
  </div>

  <div class="stats-band" aria-label="RiotScale results">
    <div class="stats-inner container">
      {
        stats.map((stat) => (
          <article class="home-stat">
            <span aria-hidden="true"></span>
            <strong>{stat.value}</strong>
            <p>{stat.label}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
