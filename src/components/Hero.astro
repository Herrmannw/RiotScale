---
import blocksImage from "../../assets/ChatGPT Image May 16, 2026, 04_27_05 PM (1).png";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-inner container">
    <div class="hero-content">
      <h1 id="hero-title">
        <span>Scale Your Brand.</span>
        <span>Maximize Impact.</span>
      </h1>
      <p>
        We help ambitious businesses unlock growth through data-driven marketing,
        performance creative, and measurable strategy.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={`${baseUrl}services/`}>Explore Our Services</a>
        <a class="text-link" href={`${baseUrl}testimonials/`}>
          View Testimonials
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h13"></path>
            <path d="m13 6 6 6-6 6"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <img src={blocksImage.src} alt="" loading="eager" decoding="async" />
    </div>
  </div>
</section>
