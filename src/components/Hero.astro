---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-content">
    <h1 id="hero-title">
      <span>Scale Your Brand.</span>
      <span>Maximize Impact.</span>
    </h1>
    <p>
      We help ambitious businesses unlock growth through data-driven marketing,
      performance creative, and measurable strategy.
    </p>

    <div class="hero-actions">
      <a class="button button-primary" href="#">Explore Our Services</a>
      <a class="text-link" href="#">
        View Case Studies
        <span aria-hidden="true">-></span>
      </a>
    </div>
  </div>

  <div class="hero-visual" aria-hidden="true">
    <div class="bar bar-small"></div>
    <div class="bar bar-mid"></div>
    <div class="bar bar-light"></div>
    <div class="bar bar-tall">
      <span class="bar-mark"></span>
    </div>
  </div>
</section>
