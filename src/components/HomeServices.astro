---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const services = [
  {
    title: "Website Strategy",
    body: "Clarify the offer, audience, and conversion path before design decisions stack up.",
    chips: ["Journey Mapping", "Conversion Goals"],
  },
  {
    title: "Website Design",
    body: "Shape a polished web experience that builds trust and gives visitors a clear next step.",
    chips: ["UX Direction", "Conversion Copy"],
  },
  {
    title: "SEO",
    body: "Prioritize search opportunities around intent, relevance, and business value.",
    chips: ["Search Intent", "Content Structure"],
  },
  {
    title: "Paid Media",
    body: "Test campaigns with a focused hypothesis, then scale what the signal supports.",
    chips: ["Campaign Testing", "Budget Focus"],
  },
  {
    title: "Performance Creative",
    body: "Develop messaging and assets around attention, clarity, and action.",
    chips: ["Message Angles", "Creative Systems"],
  },
  {
    title: "Analytics & CRO",
    body: "Measure the path from interest to conversion so the work keeps improving.",
    chips: ["Useful Reporting", "Iterative Testing"],
  },
];
---

<section class="home-services" aria-labelledby="home-services-title">
  <div class="home-services-inner container">
    <div class="home-section-header">
      <p class="eyebrow">/ Services</p>
      <h2 id="home-services-title">A connected growth system, not scattered tactics.</h2>
      <p>
        RiotScale brings strategy, creative, web, search, media, and measurement
        into one focused operating plan.
      </p>
    </div>

    <div class="home-service-grid">
      {
        services.map((service, index) => (
          <article class="home-service-card">
            <span class="home-card-index">{String(index + 1).padStart(2, "0")}</span>
            <h3>{service.title}</h3>
            <p>{service.body}</p>
            <div class="home-chip-row" aria-label={`${service.title} focus areas`}>
              {service.chips.map((chip) => <span>{chip}</span>)}
            </div>
            <a class="mini-link" href={`${baseUrl}contact/`}>
              Start Here <span aria-hidden="true">-&gt;</span>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
