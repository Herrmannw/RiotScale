---
import SEO from "../components/SEO.astro";

const {
  title = "RiotScale",
  description = "RiotScale helps ambitious businesses clarify growth goals, build actionable plans, and improve their marketing process.",
  canonical = "/",
  ogTitle = title,
  ogDescription = description,
  ogImage,
  ogUrl = canonical,
  ogType = "website",
  twitterCard = "summary_large_image",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${baseUrl}favicon.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      ogImage={ogImage}
      ogUrl={ogUrl}
      ogType={ogType}
      twitterCard={twitterCard}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
